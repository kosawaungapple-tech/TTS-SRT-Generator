rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function for Admin check
    function isAdmin() {
      return request.auth != null && 
        ((request.auth.token.email == "HanKo994@gmail.com" && request.auth.token.email_verified == true) ||
         (exists(/databases/$(database)/documents/sessions/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/sessions/$(request.auth.uid)).data.accessCode == 'saw_vlogs_2026'));
    }

    // Master Admin can do EVERYTHING
    match /{document=**} {
      allow read, write: if isAdmin();
    }
    
    // Public Users can only READ their own status, but CANNOT see Admin Keys
    match /settings/global_config {
      allow read: if true; // Allows the app to fetch keys for generation
      allow write: if isAdmin(); // Allow admin to change settings
    }

    // Allow anonymous users to read/write their own session to track accessCode
    match /sessions/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Allow users to get their own profile if they have the access code
    match /users/{userId} {
      allow get: if request.auth != null;
      allow update: if request.auth != null && 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['failedAttempts', 'lastFailedAttempt']));
    }

    // Allow all authenticated users to read global rules
    match /globalRules/{ruleId} {
      allow read: if request.auth != null;
    }

    // Allow history access for authenticated users (only their own)
    match /history/{historyId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null && 
        (resource.data.userId == get(/databases/$(database)/documents/sessions/$(request.auth.uid)).data.accessCode || 
         get(/databases/$(database)/documents/sessions/$(request.auth.uid)).data.accessCode == 'saw_vlogs_2026');
    }
  }
}
