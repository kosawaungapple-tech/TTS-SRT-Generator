rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: accessCode (e.g., VIP-0001)
    // Fields:
    //   - id: string (Access ID)
    //   - name: string
    //   - createdAt: string
    //   - expiryDate: string
    //   - isActive: boolean
    //   - api_key_stored: string (optional)
    //
    // Collection: config
    // Document ID: "main"
    // Fields:
    //   - gemini_api_key: string
    //   - rapidapi_key: string
    //   - openai_api_key: string
    //   - isSystemLive: boolean
    //   - allow_global_key: boolean
    //
    // Collection: sessions
    // Document ID: uid
    // Fields:
    //   - accessCode: string
    //   - createdAt: string
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function getAccessCode() {
      return exists(/databases/$(database)/documents/sessions/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/sessions/$(request.auth.uid)).data.accessCode 
        : null;
    }

    function isAdmin() {
      let accessCode = getAccessCode();
      return isAuthenticated() && accessCode == 'saw_vlogs_2026';
    }

    function isDocOwner(userId) {
      return isAuthenticated() && getAccessCode() == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'name', 'createdAt', 'expiryDate', 'isActive']) &&
             data.id is string && data.id.size() > 0 &&
             data.name is string &&
             data.createdAt is string &&
             data.expiryDate is string &&
             data.isActive is bool;
    }

    function isValidConfig(data) {
      return data.keys().hasAll(['isSystemLive']) &&
             data.isSystemLive is bool &&
             (!('total_generations' in data) || data.total_generations is number);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /sessions/{uid} {
      allow read, write: if isAuthenticated() && request.auth.uid == uid;
    }

    match /users/{userId} {
      // Anyone authenticated can try to get a specific user to log in
      allow get: if isAuthenticated();
      // Only admins can list all users
      allow list: if isAdmin();
      
      // Admins can create/update/delete users
      allow create, update, delete: if isAdmin() && isValidUser(request.resource.data);
      
      // Users can update their own API key
      allow update: if isAuthenticated() && isDocOwner(userId) && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['api_key_stored']);
    }

    match /config/main {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /globalRules/{ruleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /history/{historyId} {
      allow read: if isAuthenticated() && (resource.data.userId == getAccessCode() || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == getAccessCode();
      allow update, delete: if isAuthenticated() && (resource.data.userId == getAccessCode() || isAdmin());
    }

    match /test/{docId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
